---
import Layout from '../../../layouts/Layout.astro';
import ExercisePlayer from '../../../components/ExercisePlayer.jsx';
import RuleContent from '../../../components/RuleContent.astro';
import RichText from '../../../components/RichText.astro';
import { getAllTopicPaths, getTopicFull, getAllTopics, SUB_LEVELS, LEVEL_META } from '../../../lib/grammar.js';
import { RELATED_TOPICS } from '../../../lib/relatedTopics.js';
import { TOPIC_SEO } from '../../../lib/topicSeo.js';
import '../../../styles/global.css';

// True when a rule's JSONB content (object, array, or plain string) holds
// anything worth rendering — used to skip the white body only when it would
// otherwise be empty.
const hasRenderable = (v) => {
  if (v == null || v === '') return false;
  if (Array.isArray(v)) return v.length > 0;
  if (typeof v === 'object') return Object.keys(v).length > 0;
  return true;
};

// word_breakdown is stored as a plain object whose key order does NOT follow the
// sentence (e.g. "Der Tisch ist groß." → {Der, ist, Tisch, groß}, or "Ich gebe
// dem Mann das Buch." → {Ich, gebe, das Buch, dem Mann}). Re-order the rows to
// match the actual word order of sentence_de. Keys may be multi-word phrase
// chunks ("dem Mann", "in Berlin"), so match by position within the sentence,
// not by single-token lookup. Chunks not found keep their relative order at the
// end (stable).
const orderBySentence = (rows, sentence) => {
  if (!sentence || !Array.isArray(rows)) return rows;
  // Lowercase, collapse anything non-letter/number to single spaces.
  const clean = (s) => String(s).toLowerCase().replace(/[^\p{L}\p{N}]+/gu, ' ').trim();
  const sNorm = clean(sentence);
  const padded = ` ${sNorm} `;
  const sTokens = sNorm ? sNorm.split(' ') : [];
  const BIG = Number.MAX_SAFE_INTEGER;
  const posOf = (chunk) => {
    const w = clean(chunk);
    if (!w) return BIG;
    // Whole word/phrase match on space boundaries (handles "dem mann").
    const idx = padded.indexOf(` ${w} `);
    if (idx !== -1) return idx;
    // Fallback: position of the chunk's first token, ranked after phrase matches.
    const ti = sTokens.indexOf(w.split(' ')[0]);
    return ti === -1 ? BIG : 1_000_000 + ti;
  };
  return rows
    .map((r, i) => ({ r, i, p: posOf(r.word) }))
    .sort((a, b) => (a.p - b.p) || (a.i - b.i))
    .map((x) => x.r);
};

export async function getStaticPaths() {
  const paths = await getAllTopicPaths();
  return paths.map(({ slug, sub_level }) => ({
    params: { level: sub_level, slug },
  }));
}

const { level, slug } = Astro.params;
const data = await getTopicFull(level, slug);

if (!data) {
  return Astro.redirect('/grammar', 302);
}

const { topic, rules, examples, exercises, prev, next } = data;
const meta = LEVEL_META[level] ?? LEVEL_META['a1.1'];

// Related topics: prefer the DB `related_slugs` column when populated, otherwise
// fall back to the static grammatical mapping. Resolve each slug to a full topic
// (for its title + level) and drop unknowns / self-references.
const allTopics = await getAllTopics();
const topicIndex = new Map(allTopics.map((t) => [t.slug, t]));
const relatedSlugs = (Array.isArray(topic.related_slugs) && topic.related_slugs.length > 0)
  ? topic.related_slugs
  : (RELATED_TOPICS[slug] ?? []);
const relatedTopics = relatedSlugs
  .filter((s) => s && s !== slug)
  .map((s) => topicIndex.get(s))
  .filter(Boolean)
  .slice(0, 5);

const topicTitle = topic?.title_en ?? slug;
const canonicalUrl = `https://deutsch-meister.de/grammar/${level}/${slug}`;
// Site is trailingSlash: 'always' — the no-slash URL 301-redirects to this.
// canonical/og:url must match the final URL (and the sitemap) exactly.
const canonicalUrlSlash = `${canonicalUrl}/`;

const pageTitle = `German ${topicTitle} Explained in English | ${meta.label} Grammar Guide`;
const pageDesc = topic?.description_en
  ? `${topic.description_en} Includes rules, examples, and practice exercises for ${meta.label} German learners.`.slice(0, 160)
  : `Learn German ${topicTitle} explained in English with clear rules, real examples, and interactive exercises. ${meta.label} level.`.slice(0, 160);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',      item: 'https://deutsch-meister.de/' },
    { '@type': 'ListItem', position: 2, name: 'Grammar', item: 'https://deutsch-meister.de/grammar/' },
    { '@type': 'ListItem', position: 3, name: meta.label,  item: `https://deutsch-meister.de/grammar/${level}/` },
    { '@type': 'ListItem', position: 4, name: topicTitle,  item: canonicalUrlSlash },
  ],
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDesc,
  url: canonicalUrlSlash,
  inLanguage: 'en',
  publisher: { '@type': 'Organization', name: 'DeutschMeister', url: 'https://deutsch-meister.de' },
  educationalLevel: meta.label,
  about: { '@type': 'Thing', name: `German grammar: ${topicTitle}` },
};

// Per-topic SEO enrichment (snippet intro + FAQ section + FAQPage schema).
const seoExtra = TOPIC_SEO[`${level}/${slug}`];
const jsonLdSchemas = [breadcrumbSchema, articleSchema];
if (seoExtra?.faqs?.length) {
  jsonLdSchemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: seoExtra.faqs.map(({ q, a }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: { '@type': 'Answer', text: a },
    })),
  });
}
---

<Layout title={pageTitle} description={pageDesc} canonical={canonicalUrlSlash} jsonLd={jsonLdSchemas}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8 flex-wrap" aria-label="Breadcrumb">
      <a href="https://deutsch-meister.de/" class="hover:text-slate-700 transition-colors">Home</a>
      <span>/</span>
      <a href="/grammar" class="hover:text-slate-700 transition-colors">Grammar</a>
      <span>/</span>
      <a href={`/grammar/${level}`} class="hover:text-slate-700 transition-colors">{meta.label}</a>
      <span>/</span>
      <span class="text-slate-800 font-medium">{topic.title_en}</span>
    </nav>

    <!-- Level badge -->
    <div class={`inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold ${meta.badge} mb-4`}>
      {meta.label} · {meta.name}
    </div>

    <!-- Title -->
    <h1 class="font-display text-4xl sm:text-5xl font-bold text-slate-900 mb-2 leading-tight">
      {topicTitle}
    </h1>
    {topic?.title_de && topic.title_de !== topicTitle && (
      <p class="text-xl text-slate-500 mb-6 font-display">{topic.title_de}</p>
    )}

    {seoExtra?.snippetIntro && (
      <p class="text-lg text-slate-700 leading-relaxed mb-4">
        {seoExtra.snippetIntro}
      </p>
    )}

    {topic?.description_en && (
      <p class="text-lg text-slate-600 leading-relaxed mb-8 border-l-4 border-slate-200 pl-4">
        {topic.description_en}
      </p>
    )}

    <!-- Introduction -->
    {topic?.introduction_en && (
      <section class="mb-10 prose prose-slate max-w-none">
        <h2 class="font-display text-2xl font-bold text-slate-800 mb-3">Introduction</h2>
        <div class="text-slate-700 leading-relaxed whitespace-pre-line">{topic.introduction_en}</div>
      </section>
    )}

    <!-- Rules -->
    {rules.length > 0 && (
      <section class="mb-10">
        <h2 class="font-display text-2xl font-bold text-slate-800 mb-5">Rules & Explanations</h2>
        <div class="space-y-6">
          {rules.map((rule) => {
            // content may be a plain string, a parsed object, an array, or null
            const raw = rule.content;
            const content = (raw && typeof raw === 'object' && !Array.isArray(raw)) ? raw : null;
            const isIntro = rule.rule_type === 'introduction';

            // common_mistakes: guard for null / non-array
            const mistakes = Array.isArray(rule.common_mistakes) ? rule.common_mistakes : [];

            // key_insight / memory_trick can live on their own columns OR nested
            // inside the content JSONB. The generic renderer surfaces the nested
            // ones, so the column callouts below fire only for the column values
            // (avoids double-rendering the same insight).
            const showColKeyInsight = !!rule.key_insight_en;
            const showColMemoryTrick = !!rule.memory_trick_en;

            // Only render the white body when it will actually contain something.
            const showBody = (isIntro && !!content)
              || (!isIntro && hasRenderable(raw))
              || showColKeyInsight || showColMemoryTrick || mistakes.length > 0;

            return (
              <div class={`rounded-2xl border-2 ${meta.border} overflow-hidden`}>
                <div class={`px-5 py-4 ${meta.bg}`}>
                  <h3 class="font-display text-lg font-bold text-slate-800"><RichText text={rule.title_en} /></h3>
                  {rule.title_de && rule.title_de !== rule.title_en && (
                    <p class="text-sm text-slate-500 mt-0.5"><RichText text={rule.title_de} /></p>
                  )}
                </div>

                {showBody && (
                <div class="px-5 py-4 bg-white">
                  {/* Introduction rule type — custom rich content fields */}
                  {isIntro && content && (
                    <div class="space-y-4">
                      {content.hook_en && (
                        <p class="text-base font-semibold text-slate-800"><RichText text={content.hook_en} /></p>
                      )}
                      {content.german_difference_en && (
                        <p class="text-sm text-slate-700 leading-relaxed"><RichText text={content.german_difference_en} /></p>
                      )}
                      {content.english_comparison_en && (
                        <p class="text-sm text-slate-600 leading-relaxed"><RichText text={content.english_comparison_en} /></p>
                      )}
                      {content.scenario_en && (
                        <div class="p-3 rounded-lg bg-slate-50 border border-slate-200 text-sm text-slate-700">
                          <span class="font-semibold text-slate-500 text-xs uppercase tracking-wider block mb-1">Why you need this</span>
                          <RichText text={content.scenario_en} />
                        </div>
                      )}
                      {content.preview_example_de && (
                        <div class="p-3 rounded-lg border border-slate-200 bg-white">
                          <p class="font-display text-lg font-bold text-slate-900">{content.preview_example_de}</p>
                          {content.preview_example_en && (
                            <p class="text-sm text-slate-500 italic mt-0.5">{content.preview_example_en}</p>
                          )}
                          {content.preview_note_en && (
                            <p class="text-xs text-amber-700 mt-2 bg-amber-50 px-2 py-1 rounded"><RichText text={content.preview_note_en} /></p>
                          )}
                        </div>
                      )}
                      {content.why_it_matters_en && (
                        <div class="flex items-start gap-3 p-3 rounded-xl bg-amber-50 border border-amber-200">
                          <span class="text-amber-500 text-lg flex-shrink-0">💡</span>
                          <p class="text-sm text-amber-900"><RichText text={content.why_it_matters_en} /></p>
                        </div>
                      )}
                    </div>
                  )}

                  {/* All other rule types — recursive, shape-aware renderer that
                      handles bilingual prose, string lists, sections, steps,
                      mistakes, dialogue, nested tables and grouped objects. */}
                  {!isIntro && hasRenderable(raw) && (
                    <RuleContent node={raw} meta={meta} />
                  )}

                  {/* Key insight (column) */}
                  {showColKeyInsight && (
                    <div class="mt-4 flex items-start gap-3 p-3 rounded-xl bg-amber-50 border border-amber-200">
                      <span class="text-amber-500 text-lg flex-shrink-0">💡</span>
                      <p class="text-sm text-amber-900 font-medium"><RichText text={rule.key_insight_en} /></p>
                    </div>
                  )}

                  {/* Memory trick (column) */}
                  {showColMemoryTrick && (
                    <div class="mt-3 flex items-start gap-3 p-3 rounded-xl bg-purple-50 border border-purple-200">
                      <span class="text-purple-500 text-lg flex-shrink-0">🧠</span>
                      <p class="text-sm text-purple-900"><RichText text={rule.memory_trick_en} /></p>
                    </div>
                  )}

                  {/* Common mistakes — shape: {wrong, correct, explanation_en} or plain string */}
                  {mistakes.length > 0 && (
                    <div class="mt-3 p-3 rounded-xl bg-red-50 border border-red-200">
                      <p class="text-xs font-bold text-red-700 uppercase tracking-wider mb-2">Common Mistakes</p>
                      <ul class="space-y-3">
                        {mistakes.map((m) => (
                          <li class="text-sm text-red-800">
                            {typeof m === 'string' ? (
                              <span class="flex items-start gap-2">
                                <span class="flex-shrink-0 mt-0.5">✗</span>
                                <span>{m}</span>
                              </span>
                            ) : (
                              <div class="space-y-0.5">
                                {m.wrong && (
                                  <p class="flex items-start gap-2">
                                    <span class="flex-shrink-0 font-bold text-red-600">✗</span>
                                    <span class="line-through text-red-600">{m.wrong}</span>
                                  </p>
                                )}
                                {m.correct && (
                                  <p class="flex items-start gap-2">
                                    <span class="flex-shrink-0 font-bold text-emerald-600">✓</span>
                                    <span class="text-emerald-700 font-medium">{m.correct}</span>
                                  </p>
                                )}
                                {m.explanation_en && (
                                  <p class="text-xs text-slate-600 pl-5"><RichText text={m.explanation_en} /></p>
                                )}
                              </div>
                            )}
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>
                )}
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Examples -->
    {examples.length > 0 && (
      <section class="mb-10">
        <h2 class="font-display text-2xl font-bold text-slate-800 mb-5">Examples</h2>
        <div class="space-y-4">
          {examples.map((ex) => {
            // word_breakdown can be:
            //   - null / undefined
            //   - a plain object: { "Wie": "how/what", "du": "you" }  ← actual shape
            //   - an array of { word, translation, role } objects
            const rawBreakdown = ex.word_breakdown;
            let breakdownRows = null;
            if (Array.isArray(rawBreakdown) && rawBreakdown.length > 0) {
              // Array of objects — already the expected shape
              breakdownRows = rawBreakdown.map((w) => ({
                word: w.word ?? w.de ?? String(w[0] ?? ''),
                meaning: w.translation ?? w.en ?? String(w[1] ?? ''),
                role: w.role ?? w.function ?? w[2] ?? null,
              }));
            } else if (rawBreakdown && typeof rawBreakdown === 'object') {
              // Plain object: keys are German words, values are meanings
              breakdownRows = Object.entries(rawBreakdown).map(([word, meaning]) => ({
                word,
                meaning: String(meaning),
                role: null,
              }));
            }

            // Present the words in the sentence's actual order, not the DB's.
            if (breakdownRows) breakdownRows = orderBySentence(breakdownRows, ex.sentence_de);

            return (
              <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden">
                <div class="px-5 py-4">
                  <p class="font-display text-xl font-bold text-slate-900 mb-1">{ex.sentence_de}</p>
                  <p class="text-slate-500 italic text-sm mb-2">{ex.sentence_en}</p>

                  {ex.grammar_highlight && (
                    <span class={`inline-block text-xs font-semibold px-2 py-0.5 rounded-full ${meta.badge}`}>
                      {ex.grammar_highlight}
                    </span>
                  )}

                  {ex.explanation_en && (
                    <p class="mt-3 text-sm text-slate-600 leading-relaxed">{ex.explanation_en}</p>
                  )}

                  {/* Word breakdown table */}
                  {breakdownRows && breakdownRows.length > 0 && (
                    <div class="mt-4 overflow-x-auto">
                      <table class="w-full text-xs border-collapse">
                        <thead>
                          <tr class="bg-slate-50">
                            <th class="px-3 py-2 text-left font-semibold text-slate-600 border border-slate-200">Word</th>
                            <th class="px-3 py-2 text-left font-semibold text-slate-600 border border-slate-200">Meaning</th>
                            {breakdownRows.some((r) => r.role) && (
                              <th class="px-3 py-2 text-left font-semibold text-slate-600 border border-slate-200">Function</th>
                            )}
                          </tr>
                        </thead>
                        <tbody>
                          {breakdownRows.map((w, i) => (
                            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                              <td class="px-3 py-2 border border-slate-200 font-accent font-medium">{w.word}</td>
                              <td class="px-3 py-2 border border-slate-200 text-slate-600 italic">{w.meaning}</td>
                              {breakdownRows.some((r) => r.role) && (
                                <td class="px-3 py-2 border border-slate-200 text-slate-500">{w.role ?? '—'}</td>
                              )}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Exercises (React island — lazy loaded on scroll into view) -->
    {exercises.length > 0 && (
      <section class="mb-10">
        <h2 class="font-display text-2xl font-bold text-slate-800 mb-2">Practice Exercises</h2>
        <p class="text-slate-500 text-sm mb-5">{exercises.length} interactive {exercises.length === 1 ? 'exercise' : 'exercises'}</p>
        <div class="rounded-2xl border-2 border-indigo-100 bg-white p-6">
          <ExercisePlayer exercises={exercises} client:visible />
        </div>
      </section>
    )}

    <!-- Upgrade CTA -->
    <div class={`rounded-2xl border ${meta.border} ${meta.bg} p-6 mb-10 text-center`}>
      <p class="font-display text-xl font-bold text-slate-800 mb-1">
        Grammar is just the beginning
      </p>
      <p class="text-slate-600 text-sm mb-4">
        Practice {topicTitle} in real conversations with your AI language partner.
      </p>
      <a
        href="https://deutsch-meister.de/signup"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-amber-500 to-rose-500 text-white font-semibold text-sm hover:from-amber-600 hover:to-rose-600 transition-all shadow-md shadow-amber-200"
      >
        Get started free — 7 days of Pro included
      </a>
    </div>

    <!-- Related Topics -->
    {relatedTopics.length > 0 && (
      <section class="mb-10">
        <h2 class="font-display text-2xl font-bold text-slate-800 mb-5">Related Topics</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {relatedTopics.map((rt) => {
            const rmeta = LEVEL_META[rt.sub_level] ?? meta;
            return (
              <a
                href={`/grammar/${rt.sub_level}/${rt.slug}`}
                class="flex items-start gap-3 p-4 rounded-xl border border-slate-200 bg-white hover:shadow-md hover:border-slate-300 transition-all group"
              >
                <span class={`flex-shrink-0 mt-0.5 px-2 py-0.5 rounded-full text-[10px] font-bold ${rmeta.badge}`}>
                  {rmeta.label}
                </span>
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-slate-800 group-hover:text-slate-900">{rt.title_en}</p>
                  {rt.description_en && (
                    <p class="text-xs text-slate-500 leading-snug mt-0.5 line-clamp-2">{rt.description_en}</p>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Per-topic FAQ (see src/lib/topicSeo.js) -->
    {seoExtra?.faqs?.length > 0 && (
      <section class="mb-10">
        <h2 class="font-display text-2xl font-bold text-slate-800 mb-5">{seoExtra.faqHeading ?? 'Common questions'}</h2>
        <div class="space-y-3">
          {seoExtra.faqs.map(({ q, a }) => (
            <details class="rounded-2xl border border-slate-200 bg-white overflow-hidden group">
              <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer list-none font-semibold text-slate-800 hover:bg-slate-50 transition-colors">
                <span>{q}</span>
                <span class="text-slate-400 flex-shrink-0 transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
              </summary>
              <p class="px-5 pb-5 pt-1 text-sm text-slate-600 leading-relaxed">{a}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- Prev / Next navigation -->
    <nav class="flex items-center justify-between gap-4 pt-6 border-t border-slate-200">
      {prev ? (
        <a
          href={`/grammar/${level}/${prev.slug}`}
          class="flex items-center gap-2 px-4 py-3 rounded-xl border border-slate-200 bg-white hover:shadow-md transition-all group max-w-[45%]"
        >
          <svg class="w-4 h-4 text-slate-400 group-hover:-translate-x-0.5 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <div class="min-w-0">
            <p class="text-xs text-slate-400 mb-0.5">Previous</p>
            <p class="text-sm font-semibold text-slate-700 truncate">{prev?.title_en ?? prev?.slug}</p>
          </div>
        </a>
      ) : (
        <div />
      )}

      {next ? (
        <a
          href={`/grammar/${level}/${next.slug}`}
          class="flex items-center gap-2 px-4 py-3 rounded-xl border border-slate-200 bg-white hover:shadow-md transition-all group max-w-[45%] text-right ml-auto"
        >
          <div class="min-w-0">
            <p class="text-xs text-slate-400 mb-0.5">Next</p>
            <p class="text-sm font-semibold text-slate-700 truncate">{next?.title_en ?? next?.slug}</p>
          </div>
          <svg class="w-4 h-4 text-slate-400 group-hover:translate-x-0.5 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ) : (
        <div />
      )}
    </nav>

    <!-- All topics in this level -->
    <div class="mt-8 pt-6 border-t border-slate-200">
      <a href={`/grammar/${level}`} class="text-sm text-slate-500 hover:text-slate-700 transition-colors">
        ← All {meta.label} topics
      </a>
    </div>

  </div>
</Layout>
