---
import Layout from '../../layouts/Layout.astro';
import competitorComparisons from '../../data/competitorComparisons.js';
import '../../styles/global.css';

export function getStaticPaths() {
  return Object.keys(competitorComparisons).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const data = competitorComparisons[slug];

const title = `Deutschmeister vs ${data.displayName} — Vergleich | DeutschMeister`;
const description = `${data.heroHeadline} Vergleiche Deutschmeister und ${data.displayName}: Features, Preise, Sprechtraining, Prüfungsvorbereitung. Ehrlich und fair.`;
const keywords = `Deutschmeister vs ${data.displayName}, ${data.displayName} Alternative, Deutsch lernen Vergleich, ${data.displayName} Erfahrungen`;
const canonical = `https://deutsch-meister.de/vergleich/${data.slug}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `Deutschmeister vs ${data.displayName} — Vergleich`,
  description: data.heroSubheadline,
  author: { '@type': 'Organization', name: 'DeutschMeister' },
  publisher: { '@type': 'Organization', name: 'DeutschMeister' },
  datePublished: '2026-05-28',
  dateModified: '2026-05-28',
};

// ✓ / ✗ / ○ status prefixes → colour + stripped text (matches the SPA's StatusIcon).
const WHY_ICON = { Mic: '🎤', ScanSearch: '🔍', GraduationCap: '🎓', Brain: '🧠', Clock: '⏰', Wallet: '💰' };
const statusColor = (t) => (t.startsWith('✓') ? 'text-emerald-500' : t.startsWith('✗') ? 'text-red-400' : t.startsWith('○') ? 'text-amber-400' : 'text-slate-400');
const statusSymbol = (t) => (t.startsWith('✓') ? '✓' : t.startsWith('✗') ? '✗' : t.startsWith('○') ? '○' : '');
const strip = (t) => t.replace(/^[✓✗○]\s*/, '');

// Static trust stats (SPA StatsBar, last updated 2026-05-27).
const STATS = [
  { value: '959', label: 'Lernende' },
  { value: '2.488', label: 'KI-Sprechübungen' },
  { value: '350', label: 'Neue Lernende diesen Monat' },
  { value: '154', label: 'Sätze röntgen-analysiert' },
];
---

<Layout title={title} description={description} keywords={keywords} canonical={canonical} jsonLd={jsonLd}>
  <div class="bg-gradient-to-br from-slate-50 via-white to-slate-100">
    <!-- Hero -->
    <section class="pt-12 pb-16 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 bg-amber-50 text-amber-700 text-sm font-medium px-4 py-1.5 rounded-full mb-6">
          Vergleich
        </div>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-800 mb-4 leading-tight">
          {data.heroHeadline}
        </h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-8">{data.heroSubheadline}</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="https://deutsch-meister.de/signup" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-amber-500 to-rose-500 text-white font-semibold rounded-xl shadow-lg shadow-rose-500/25 hover:from-amber-600 hover:to-rose-600 transition-all">
            Kostenlos testen <span aria-hidden="true">→</span>
          </a>
          <a href="https://deutsch-meister.de/pricing" class="inline-flex items-center gap-2 px-6 py-3 border border-slate-200 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
            Preise ansehen
          </a>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="pb-16 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-slate-800 text-center mb-10">Feature-Vergleich</h2>

        <!-- Desktop table -->
        <div class="hidden md:block">
          <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="grid grid-cols-3 bg-slate-50 border-b border-slate-100">
              <div class="px-6 py-4 font-semibold text-slate-500 text-sm">Feature</div>
              <div class="px-6 py-4 font-semibold text-amber-600 text-sm">DeutschMeister</div>
              <div class="px-6 py-4 font-semibold text-slate-500 text-sm">{data.displayName}</div>
            </div>
            {data.comparisonTable.map((row, i) => (
              <div class={`grid grid-cols-3 ${i % 2 === 0 ? 'bg-white' : 'bg-slate-50/50'} ${i < data.comparisonTable.length - 1 ? 'border-b border-slate-100' : ''}`}>
                <div class="px-6 py-4 text-sm font-medium text-slate-700">{row.feature}</div>
                <div class="px-6 py-4 text-sm text-slate-600">
                  <div class="flex items-start gap-2">
                    <span class={`${statusColor(row.us)} flex-shrink-0 font-bold`}>{statusSymbol(row.us)}</span>
                    <span>{strip(row.us)}</span>
                  </div>
                </div>
                <div class="px-6 py-4 text-sm text-slate-600">
                  <div class="flex items-start gap-2">
                    <span class={`${statusColor(row.them)} flex-shrink-0 font-bold`}>{statusSymbol(row.them)}</span>
                    <span>{strip(row.them)}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Mobile stacked cards -->
        <div class="md:hidden space-y-4">
          {data.comparisonTable.map((row) => (
            <div class="bg-white rounded-xl border border-slate-100 p-4 shadow-sm">
              <p class="font-medium text-slate-800 text-sm mb-3">{row.feature}</p>
              <div class="space-y-2">
                <div class="flex items-start gap-2">
                  <span class="text-xs font-semibold text-amber-600 min-w-[24px] mt-0.5">DM</span>
                  <span class={`${statusColor(row.us)} flex-shrink-0 font-bold`}>{statusSymbol(row.us)}</span>
                  <span class="text-sm text-slate-600">{strip(row.us)}</span>
                </div>
                <div class="flex items-start gap-2">
                  <span class="text-xs font-semibold text-slate-400 min-w-[24px] mt-0.5">{data.displayName.substring(0, 2).toUpperCase()}</span>
                  <span class={`${statusColor(row.them)} flex-shrink-0 font-bold`}>{statusSymbol(row.them)}</span>
                  <span class="text-sm text-slate-600">{strip(row.them)}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Us -->
    <section class="pb-16 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-slate-800 text-center mb-10">
          Warum Deutschmeister statt {data.displayName}
        </h2>
        <div class="grid sm:grid-cols-3 gap-6">
          {data.whyUsBlocks.map((block) => (
            <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-400 to-rose-500 flex items-center justify-center mb-4 shadow-lg shadow-rose-500/20 text-2xl">
                <span aria-hidden="true">{WHY_ICON[block.icon] ?? '🎓'}</span>
              </div>
              <h3 class="font-semibold text-slate-800 mb-2">{block.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{block.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-14 bg-white border-b border-slate-100">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <p class="text-center text-xs font-semibold uppercase tracking-widest text-slate-400 mb-8">Lernende vertrauen Deutschmeister</p>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
          {STATS.map((stat) => (
            <div class="text-center">
              <p class="text-4xl sm:text-5xl font-bold text-slate-800 mb-1">{stat.value}</p>
              <p class="text-sm text-slate-500">{stat.label}</p>
            </div>
          ))}
        </div>
        <p class="text-center text-xs text-slate-400 mt-8">Stand: Mai 2026</p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 px-4 sm:px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-slate-800 text-center mb-10">
          Häufige Fragen: Deutschmeister vs {data.displayName}
        </h2>
        <div class="space-y-3">
          {data.faq.map((item) => (
            <details class="border border-slate-200 rounded-xl overflow-hidden group">
              <summary class="w-full flex items-center justify-between px-5 py-4 text-left hover:bg-slate-50 transition-colors cursor-pointer list-none">
                <span class="font-medium text-slate-800 pr-4">{item.q}</span>
                <span class="text-slate-400 flex-shrink-0 transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
              </summary>
              <div class="px-5 pb-5 text-slate-600 text-sm leading-relaxed border-t border-slate-100 pt-4">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="pb-20 px-4 sm:px-6">
      <div class="max-w-3xl mx-auto">
        <div class="bg-gradient-to-br from-slate-800 to-slate-900 rounded-3xl p-8 sm:p-12 text-center">
          <h2 class="font-display text-2xl sm:text-3xl font-bold text-white mb-3">{data.ctaHeadline}</h2>
          <p class="text-slate-400 mb-8">{data.ctaSubtext}</p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a href="https://deutsch-meister.de/signup" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-amber-500 to-rose-500 text-white font-semibold rounded-xl shadow-lg shadow-rose-500/25 hover:from-amber-600 hover:to-rose-600 transition-all">
              Kostenlos starten <span aria-hidden="true">→</span>
            </a>
            <a href="https://deutsch-meister.de/pricing" class="inline-flex items-center gap-2 px-6 py-3 border border-slate-600 text-slate-300 font-medium rounded-xl hover:bg-slate-700 transition-colors">
              Preise ansehen
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="max-w-4xl mx-auto px-4 pb-12 text-center">
      <p class="text-xs text-slate-400">
        Vergleichsdaten Stand: Mai 2026. Wir vergleichen objektiv und nach UWG §6 zulässig.
      </p>
    </div>
  </div>
</Layout>
