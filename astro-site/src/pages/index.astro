---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const title = 'Learn German Online - Free Lessons A1 to B2 | DeutschMeister';
const description = 'Master German with free interactive lessons. Grammar, vocabulary, listening exercises, and podcasts for English speakers. CEFR levels A1.1 to B2.2.';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'DeutschMeister',
    url: 'https://deutsch-meister.de/',
    description: 'Free German language learning platform for English speakers',
    inLanguage: ['de', 'en'],
    potentialAction: {
      '@type': 'SearchAction',
      target: 'https://deutsch-meister.de/search?q={search_term_string}',
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'DeutschMeister',
    url: 'https://deutsch-meister.de',
    logo: 'https://deutsch-meister.de/logo.png',
    description: 'A German language learning platform covering CEFR levels A1.1 to B2.2',
    sameAs: ['https://www.youtube.com/@deutschmeister_de'],
    contactPoint: { '@type': 'ContactPoint', email: 'contact@deutsch-meister.de', contactType: 'customer service' },
  },
];

const LEVELS = [
  { level: 'A1', icon: '☀️', color: 'from-[#F4B99A] to-[#D9A8B4]', name: 'Beginner' },
  { level: 'A2', icon: '🌲', color: 'from-[#7BAF8E] to-[#A8D4AC]', name: 'Elementary' },
  { level: 'B1', icon: '🌊', color: 'from-[#5A7A9A] to-[#B0D4E8]', name: 'Intermediate' },
  { level: 'B2', icon: '🌙', color: 'from-[#8A7AAF] to-[#BDB0D9]', name: 'Upper Intermediate' },
];

const STATS = [
  { value: '959', label: 'Lernende' },
  { value: '2.488', label: 'KI-Sprechübungen' },
  { value: '350', label: 'Neue Lernende diesen Monat' },
  { value: '154', label: 'Sätze röntgen-analysiert' },
];

// Comparison table (DeutschMeister vs alternatives).
const CMP = [
  { feature: 'Monthly Cost', dm: ['€9.99', 'pos'], group: ['€150+', 'neg'], tutor: ['€50–100', 'neg'], apps: ['€0–15', 'neu'] },
  { feature: 'AI Speaking Practice', dm: ['✓ Unlimited', 'pos'], group: ['5 min/class', 'neg'], tutor: ['✓ 1-on-1', 'pos'], apps: ['✗ None', 'neg'] },
  { feature: 'Available 24/7', dm: ['✓', 'pos'], group: ['✗ Fixed times', 'neg'], tutor: ['✗ Book ahead', 'neg'], apps: ['✓', 'pos'] },
  { feature: 'Adapts to your level', dm: ['✓ Automatic', 'pos'], group: ['✗ One pace', 'neg'], tutor: ['✓ Manual', 'pos'], apps: ['✗ Generic', 'neg'] },
  { feature: 'Grammar A1–B2', dm: ['✓ 64 topics', 'pos'], group: ['Varies', 'neu'], tutor: ['Varies', 'neu'], apps: ['✓ Varies', 'pos'] },
  { feature: 'Instant feedback', dm: ['✓ AI scoring', 'pos'], group: ['Next class', 'neg'], tutor: ['End of session', 'neg'], apps: ['✗ Basic', 'neg'] },
  { feature: 'Sentence analysis', dm: ['✓ X-Ray tool', 'pos'], group: ['✗', 'neg'], tutor: ['✗', 'neg'], apps: ['✗', 'neg'] },
  { feature: 'Free level test', dm: ['✓', 'pos'], group: ['€50+', 'neg'], tutor: ['€30+', 'neg'], apps: ['Basic quiz', 'neu'] },
];
const cellColor = (k) => (k === 'pos' ? 'text-emerald-600 font-medium' : k === 'neu' ? 'text-slate-500' : 'text-slate-400');

const TOPICS = [
  { href: '/grammar/a1.1/nouns-gender/', level: 'A1.1', label: 'Nouns & Gender', desc: 'der / die / das — why every noun has a gender' },
  { href: '/grammar/a1.2/accusative-intro/', level: 'A1.2', label: 'Accusative Case', desc: 'When "der" becomes "den" and why it matters' },
  { href: '/grammar/a2.1/prepositions-dative/', level: 'A2.1', label: 'Dative Prepositions', desc: 'mit, nach, seit, von, zu, bei, aus, gegenüber' },
  { href: '/grammar/b1.1/konjunktiv-ii-wurde/', level: 'B1.1', label: 'Konjunktiv II (würde)', desc: 'Express wishes, hypotheticals, and polite requests' },
];

const XRAY_CHIPS = [
  { text: 'Der Mann', cls: 'bg-[#E6F1FB] border-[#378ADD] text-[#0C447C]', label: 'Nominative · Subject' },
  { text: 'gibt', cls: 'bg-slate-100 border-slate-300 text-slate-700', label: 'Verb' },
  { text: 'dem Kind', cls: 'bg-[#E1F5EE] border-[#1D9E75] text-[#085041]', label: 'Dative · Indirect Obj.' },
  { text: 'einen Apfel', cls: 'bg-[#FAECE7] border-[#D85A30] text-[#712B13]', label: 'Accusative · Direct Obj.' },
];
---

<Layout title={title} description={description} canonical="https://deutsch-meister.de/" jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="relative flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-slate-100"></div>
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-1/4 -right-1/4 w-1/2 h-1/2 bg-gradient-to-br from-amber-200/30 to-orange-200/30 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-1/4 -left-1/4 w-1/2 h-1/2 bg-gradient-to-br from-purple-200/30 to-pink-200/30 rounded-full blur-3xl"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold text-slate-800 mb-6 leading-tight">
        The Fastest Way to Speak German.{' '}
        <span class="bg-gradient-to-r from-amber-500 to-rose-500 bg-clip-text text-transparent">Period.</span>
      </h1>
      <p class="text-xl sm:text-2xl text-slate-600 max-w-3xl mx-auto mb-10 leading-relaxed">
        AI-powered speaking practice at your exact CEFR level. Real conversations. Real feedback. Real results — for less than a coffee a day.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
        <a href="https://deutsch-meister.de/level-test" class="group w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-amber-500 to-rose-500 text-white font-semibold rounded-2xl shadow-lg shadow-rose-500/25 hover:shadow-xl transition-all flex items-center justify-center gap-2">
          Find Your Level — Free Test <span aria-hidden="true">→</span>
        </a>
        <a href="https://deutsch-meister.de/speaking" class="group w-full sm:w-auto px-8 py-4 border-2 border-slate-300 text-slate-700 font-semibold rounded-2xl hover:border-slate-400 hover:bg-slate-50 transition-all flex items-center justify-center gap-2">
          Try Speaking Practice <span aria-hidden="true">→</span>
        </a>
      </div>
      <p class="text-sm text-slate-500">
        ✓ No credit card required &nbsp;&nbsp; ✓ 7-day free Pro trial &nbsp;&nbsp; ✓ Cancel anytime
      </p>
      <div class="mt-20 flex flex-wrap justify-center gap-4">
        {LEVELS.map((item) => (
          <div class={`relative px-6 py-4 rounded-2xl bg-gradient-to-r ${item.color} text-white shadow-lg`}>
            <div class="flex items-center gap-3">
              <span class="text-2xl" aria-hidden="true">{item.icon}</span>
              <div class="text-left">
                <span class="text-lg font-bold">{item.level}</span>
                <p class="text-white/80 text-sm">{item.name}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-14 bg-white border-b border-slate-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <p class="text-center text-xs font-semibold uppercase tracking-widest text-slate-400 mb-8">Lernende vertrauen Deutschmeister</p>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
        {STATS.map((s) => (
          <div class="text-center">
            <p class="text-4xl sm:text-5xl font-bold text-slate-800 mb-1">{s.value}</p>
            <p class="text-sm text-slate-500">{s.label}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-xs text-slate-400 mt-8">Stand: Mai 2026</p>
    </div>
  </section>

  <!-- Level Test CTA -->
  <section class="py-16 bg-gradient-to-br from-[#e1f5ee] to-[#e6f1fb]">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-2xl sm:text-3xl font-bold text-slate-900 mb-3">Not sure where to start?</h2>
      <p class="text-lg text-slate-600 mb-6 leading-relaxed">
        Take our free German level test to find out your CEFR level and get personalized recommendations.
      </p>
      <div class="flex flex-wrap justify-center gap-4 sm:gap-6 mb-6">
        <span class="text-[#1D9E75] font-medium">✓ 40 questions</span>
        <span class="text-[#1D9E75] font-medium">✓ 15-20 minutes</span>
        <span class="text-[#1D9E75] font-medium">✓ Instant results</span>
      </div>
      <a href="https://deutsch-meister.de/level-test" class="inline-block px-8 py-4 bg-[#1D9E75] hover:bg-[#178a66] text-white text-lg font-semibold rounded-xl transition-colors shadow-md shadow-emerald-200">
        Take the Level Test
      </a>
    </div>
  </section>

  <!-- Speaking Practice CTA -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center gap-8 p-8 rounded-3xl bg-gradient-to-br from-teal-50 to-emerald-50 border border-teal-100">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-teal-400 to-emerald-500 flex items-center justify-center flex-shrink-0 text-3xl" aria-hidden="true">💬</div>
        <div class="flex-1 text-center md:text-left">
          <h3 class="text-xl font-bold text-slate-800 mb-2">Practice Speaking with AI</h3>
          <p class="text-slate-600">
            Have real-time German conversations with an AI teacher. Get feedback on pronunciation, grammar, and vocabulary at your level.
          </p>
        </div>
        <a href="https://deutsch-meister.de/speaking" class="inline-flex items-center gap-2 px-6 py-3 bg-teal-600 text-white font-semibold rounded-xl hover:bg-teal-700 transition-colors flex-shrink-0">
          Try Speaking <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="py-20 bg-white border-b border-slate-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 mb-3">See Why Learners Switch to DeutschMeister</h2>
      </div>
      <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-lg shadow-slate-100">
        <table class="w-full min-w-[640px] border-collapse text-sm">
          <thead>
            <tr class="border-b border-slate-200">
              <th class="text-left px-5 py-4 text-slate-500 font-medium bg-slate-50 w-[200px]">Feature</th>
              <th class="px-5 py-4 bg-amber-50 border-x border-amber-200 w-[160px]">
                <div class="flex flex-col items-center gap-1.5">
                  <span class="px-2.5 py-0.5 rounded-full bg-amber-400 text-white text-[10px] font-bold tracking-wide uppercase">Best Value</span>
                  <span class="font-bold text-slate-900 text-base">DeutschMeister</span>
                </div>
              </th>
              <th class="px-5 py-4 text-center text-slate-600 font-semibold bg-slate-50">Group Classes</th>
              <th class="px-5 py-4 text-center text-slate-600 font-semibold bg-slate-50">Private Tutor</th>
              <th class="px-5 py-4 text-center text-slate-600 font-semibold bg-slate-50">Grammar Apps</th>
            </tr>
          </thead>
          <tbody>
            {CMP.map((row, i) => (
              <tr class={`border-b border-slate-100 ${i % 2 === 1 ? 'bg-slate-50/50' : ''}`}>
                <td class="px-5 py-3.5 text-slate-700 font-medium">{row.feature}</td>
                <td class="px-5 py-3.5 text-center bg-amber-50/70 border-x border-amber-100"><span class={cellColor(row.dm[1])}>{row.dm[0]}</span></td>
                <td class="px-5 py-3.5 text-center"><span class={cellColor(row.group[1])}>{row.group[0]}</span></td>
                <td class="px-5 py-3.5 text-center"><span class={cellColor(row.tutor[1])}>{row.tutor[0]}</span></td>
                <td class="px-5 py-3.5 text-center"><span class={cellColor(row.apps[1])}>{row.apps[0]}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="text-center mt-10">
        <a href="https://deutsch-meister.de/signup" class="group inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-amber-500 to-rose-500 text-white font-semibold rounded-2xl shadow-lg shadow-rose-500/25 hover:shadow-xl transition-all">
          Start Your Free Trial <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Urgency / Pain -->
  <section class="py-20 bg-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-4xl sm:text-5xl font-bold text-white mb-10 leading-tight">
        Your German Won't Improve<br class="hidden sm:block" /> By Waiting.
      </h2>
      <div class="grid sm:grid-cols-3 gap-6 mb-12">
        {["Every day you delay is another conversation you can't have.", 'Another job opportunity that passes you by.', 'Another moment where you freeze instead of speak.'].map((text) => (
          <div class="px-5 py-5 rounded-2xl bg-slate-800 border border-slate-700 text-slate-300 text-base leading-relaxed">{text}</div>
        ))}
      </div>
      <p class="text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto mb-12 leading-relaxed">
        Start your free trial today. <span class="text-white font-semibold">7 days of full Pro access.</span> If it's not for you, cancel with one click — no charge, no questions.
      </p>
      <div class="grid sm:grid-cols-2 gap-5 max-w-xl mx-auto">
        <div class="rounded-2xl bg-slate-800 border border-slate-700 p-6 flex flex-col items-center gap-4">
          <div class="text-center">
            <p class="text-white font-bold text-lg">Pro Monthly</p>
            <p class="text-slate-400 text-sm">€9.99 / month</p>
          </div>
          <a href="https://deutsch-meister.de/signup" class="group w-full inline-flex items-center justify-center gap-2 px-6 py-3 bg-gradient-to-r from-amber-500 to-rose-500 text-white font-semibold rounded-xl shadow-lg transition-all">
            Start Free Trial <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="rounded-2xl bg-slate-800 border border-slate-700 p-6 flex flex-col items-center gap-4">
          <div class="text-center">
            <div class="inline-flex items-center gap-1.5 mb-1">
              <p class="text-white font-bold text-lg">Pro Yearly</p>
              <span class="px-2 py-0.5 rounded-full bg-green-500 text-white text-[10px] font-bold">Save 33%</span>
            </div>
            <p class="text-slate-400 text-sm">€79.99 / year</p>
            <p class="text-green-400 text-xs mt-0.5">That's €0.22/day — less than a coffee</p>
          </div>
          <a href="https://deutsch-meister.de/signup" class="group w-full inline-flex items-center justify-center gap-2 px-6 py-3 bg-gradient-to-r from-amber-500 to-rose-500 text-white font-semibold rounded-xl shadow-lg transition-all">
            Start Free Trial <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sentence X-Ray Feature -->
  <section class="py-20 bg-gradient-to-b from-slate-50 to-white border-b border-slate-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-12">
        <div class="flex-1 text-center lg:text-left">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-100 text-violet-700 text-xs font-semibold mb-4">
            <span aria-hidden="true">🔍</span> New Tool
          </div>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 mb-4 leading-tight">Understand Any German Sentence Instantly</h2>
          <p class="text-lg text-slate-600 mb-6 leading-relaxed">Paste any sentence. See cases, roles, and why — in seconds.</p>
          <div class="flex flex-wrap justify-center lg:justify-start gap-x-5 gap-y-2 mb-8">
            {['Works with any sentence', 'Color-coded cases', 'Explains the WHY'].map((v) => (
              <span class="flex items-center gap-1.5 text-sm text-slate-600">
                <span class="w-4 h-4 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center text-[10px] font-bold flex-shrink-0">✓</span>{v}
              </span>
            ))}
          </div>
          <a href="https://deutsch-meister.de/analyze" class="inline-flex items-center gap-2 px-7 py-3.5 bg-gradient-to-r from-violet-500 to-indigo-600 text-white font-semibold rounded-2xl hover:from-violet-600 hover:to-indigo-700 transition-all shadow-lg shadow-indigo-200 text-base">
            <span aria-hidden="true">🔍</span> Try Sentence X-Ray <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="flex-1 w-full max-w-md lg:max-w-none">
          <div class="bg-white rounded-2xl border border-slate-200 shadow-xl shadow-slate-200/60 p-5">
            <div class="flex items-center gap-3 p-3 rounded-xl bg-slate-50 border border-slate-200 mb-4">
              <span class="flex-1 text-sm text-slate-600 font-medium">Der Mann gibt dem Kind einen Apfel.</span>
              <a href="https://deutsch-meister.de/analyze" class="flex-shrink-0 flex items-center gap-1.5 px-3 py-1.5 bg-gradient-to-r from-violet-500 to-indigo-600 text-white text-xs font-semibold rounded-lg hover:from-violet-600 hover:to-indigo-700 transition-all">
                <span aria-hidden="true">🔍</span> Analyze
              </a>
            </div>
            <div class="flex flex-wrap gap-2 mb-4">
              {XRAY_CHIPS.map((chip) => (
                <div class="flex flex-col gap-1">
                  <span class={`px-3 py-1.5 rounded-lg text-sm font-semibold border ${chip.cls}`}>{chip.text}</span>
                  <span class="text-[10px] text-slate-400 px-1">{chip.label}</span>
                </div>
              ))}
            </div>
            <div class="p-3 rounded-xl bg-amber-50 border border-amber-200">
              <p class="text-xs font-semibold text-amber-600 mb-0.5">Key Insight</p>
              <p class="text-xs text-slate-700 leading-relaxed">
                Cases tell German who does what — not word order. <span class="font-medium">"dem Kind"</span> is dative because it receives the apple indirectly.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Grammar Topics -->
  <section class="py-16 bg-slate-50 border-t border-slate-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-slate-900 mb-2">Start with the Most Important Topics</h2>
        <p class="text-slate-600">Free grammar lessons explained in English — rules, examples, and exercises.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-3 mb-6">
        {TOPICS.map((t) => (
          <a href={t.href} class="flex items-start gap-4 p-4 bg-white rounded-xl border border-slate-200 hover:border-amber-300 hover:shadow-md transition-all group">
            <span class="flex-shrink-0 px-2 py-0.5 rounded-md bg-amber-100 text-amber-800 text-xs font-bold mt-0.5">{t.level}</span>
            <div class="min-w-0">
              <p class="font-semibold text-slate-800 group-hover:text-amber-700 transition-colors text-sm">German {t.label} Explained</p>
              <p class="text-xs text-slate-500 mt-0.5 leading-snug">{t.desc}</p>
            </div>
            <span class="text-slate-300 group-hover:text-amber-500 transition-all flex-shrink-0 mt-0.5" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
      <div class="text-center">
        <a href="/grammar" class="inline-flex items-center gap-1.5 text-sm font-semibold text-amber-700 hover:text-amber-900 transition-colors">
          Browse all 64 grammar topics <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-gradient-to-r from-amber-500 via-rose-500 to-purple-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-4xl sm:text-5xl font-bold text-white mb-6">350+ Learners Are Already Practicing. Are You Next?</h2>
      <a href="https://deutsch-meister.de/signup" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-rose-600 font-semibold rounded-2xl hover:bg-slate-50 transition-colors shadow-lg">
        Start Your Free 7-Day Trial <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- Learn on YouTube -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-red-600 flex items-center justify-center shadow-lg shadow-red-200 text-2xl" aria-hidden="true">▶</div>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-800 mb-3">Learn on YouTube</h2>
      <p class="text-slate-600 text-lg mb-8 max-w-lg mx-auto">
        Watch our German lessons on YouTube — new videos every week covering grammar, vocabulary, and real conversations.
      </p>
      <a href="https://www.youtube.com/@deutschmeister_de" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-red-600 text-white font-semibold rounded-xl hover:bg-red-700 transition-colors shadow-lg shadow-red-200">
        Subscribe on YouTube <span aria-hidden="true">↗</span>
      </a>
    </div>
  </section>
</Layout>
